# Supabase Configuration (BẮT BUỘC)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...YOUR_ANON_KEY_HERE

# Google Apps Script Web App URL (cho sync trigger)
